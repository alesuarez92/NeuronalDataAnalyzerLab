# EditorConfig: https://editorconfig.org
# Use "EditorConfig: Open Settings" (or similar) in your editor if supported.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.m]
indent_style = space
indent_size = 4

[*.{md,txt,yml,yaml}]
indent_size = 2
